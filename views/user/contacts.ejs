<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container my-5">
  <!-- Title Header -->
  <div class="text-center mb-5">
    <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3 py-2 fw-semibold mb-2">TELEPON DARURAT</span>
    <h1 class="fw-bold mb-2">Kontak Gawat Darurat</h1>
    <p class="text-muted col-lg-6 mx-auto">Daftar nomor telepon darurat instansi medis, penyelamatan, keamanan, dan rumah sakit rujukan utama.</p>
  </div>

  <div class="row g-4">
    <% if (contacts && contacts.length > 0) { %>
      <% contacts.forEach(contact => { %>
        <div class="col-md-6 col-lg-4">
          <div class="card card-premium h-100 contact-card p-4 d-flex flex-column justify-content-between">
            <div>
              <div class="d-flex align-items-center mb-3">
                <div class="bg-danger bg-opacity-10 text-danger rounded-circle p-3 me-3 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                  <i class="bi bi-telephone-plus-fill fs-4"></i>
                </div>
                <div>
                  <h5 class="fw-bold mb-1 text-dark text-truncate-2" style="font-size: 1.15rem;"><%= contact.nama_instansi %></h5>
                </div>
              </div>

              <% if (contact.alamat) { %>
                <p class="small text-muted mb-2">
                  <i class="bi bi-geo-alt-fill text-danger me-1"></i> <%= contact.alamat %>
                </p>
              <% } %>

              <% if (contact.keterangan) { %>
                <p class="small text-muted-50 mb-3" style="font-style: italic;">
                  <i class="bi bi-info-circle me-1"></i> <%= contact.keterangan %>
                </p>
              <% } %>
            </div>

            <div class="mt-3">
              <a href="tel:<%= contact.nomor_telepon.replace(/[^0-9]/g, '') %>" class="phone-pill w-100 text-center py-2">
                <i class="bi bi-telephone-outbound me-2"></i> <%= contact.nomor_telepon %>
              </a>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="col-12 text-center py-5">
        <i class="bi bi-telephone-x text-muted" style="font-size: 5rem;"></i>
        <h4 class="mt-3 fw-bold text-secondary">Kontak Darurat Kosong</h4>
        <p class="text-muted">Belum ada nomor kontak darurat yang dimasukkan ke dalam sistem.</p>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
