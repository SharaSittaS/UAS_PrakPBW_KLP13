<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container my-5">
  <!-- Breadcrumbs -->
  <nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">Beranda</a></li>
      <li class="breadcrumb-item"><a href="/guides" class="text-decoration-none text-muted">Panduan</a></li>
      <li class="breadcrumb-item active text-danger" aria-current="page"><%= guide.judul %></li>
    </ol>
  </nav>

  <div class="row g-4">
    <!-- Main Content (Column 8) -->
    <div class="col-lg-8">
      <!-- Title Block -->
      <div class="mb-4">
        <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3 py-2 fw-semibold mb-2"><%= guide.kategori_nama %></span>
        <h1 class="fw-bold mb-3"><%= guide.judul %></h1>
        <div class="d-flex flex-wrap align-items-center gap-3 text-muted small">
          <span><i class="bi bi-person me-1"></i> Ditulis oleh: <strong><%= guide.pembuat_nama || 'Admin' %></strong></span>
          <span><i class="bi bi-calendar3 me-1"></i> Dipublikasi: <strong><%= new Date(guide.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %></strong></span>
        </div>
      </div>

      <!-- Image -->
      <div class="guide-image-container mb-4">
        <% if (guide.gambar) { %>
          <img src="/uploads/<%= guide.gambar %>" alt="<%= guide.judul %>">
        <% } else { %>
          <div class="placeholder-guide-img text-center py-5 d-flex flex-column align-items-center justify-content-center" style="height: 350px;">
            <i class="bi bi-heart-pulse text-danger fs-1 mb-2"></i>
            <h5 class="text-muted fw-bold">FirstAid Guide</h5>
            <p class="text-muted-50 small mb-0">Foto/Ilustrasi penanganan mandiri belum terunggah</p>
          </div>
        <% } %>
      </div>

      <!-- Symptoms Section (Gejala) -->
      <div class="card-premium p-4 mb-4" style="border-left: 5px solid var(--accent-color);">
        <h4 class="fw-bold mb-3 text-gradient"><i class="bi bi-exclamation-octagon me-2 text-danger"></i>Gejala / Tanda Klinis</h4>
        <p class="mb-0" style="white-space: pre-wrap; font-size: 1.05rem; line-height: 1.6;"><%= guide.gejala %></p>
      </div>

      <!-- Steps Section (Langkah Penanganan) -->
      <div class="mb-5">
        <h4 class="fw-bold mb-4 text-gradient"><i class="bi bi-list-check me-2 text-danger"></i>Langkah-Langkah Pertolongan Pertama</h4>
        
        <% 
          // Split langkah penanganan berdasarkan baris baru untuk dirender satu per satu
          const steps = guide.langkah_penanganan.split(/\r?\n/).filter(line => line.trim() !== '');
        %>
        
        <% if (steps.length > 0) { %>
          <% steps.forEach((step, index) => { %>
            <div class="step-card d-flex align-items-start">
              <span class="step-number"><%= index + 1 %></span>
              <div class="flex-grow-1">
                <% 
                  // Hilangkan angka "1. ", "2. " di awal string jika ada agar tidak double penomoran
                  const cleanStep = step.replace(/^\d+[\.\)\s]+/, '').trim();
                %>
                <p class="mb-0 fs-5" style="color: #334155;"><%= cleanStep %></p>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <p class="text-muted">Langkah penanganan belum ditambahkan.</p>
        <% } %>
      </div>
    </div>

    <!-- Sidebar (Column 4) -->
    <div class="col-lg-4">
      <!-- Emergency Card -->
      <div class="card-premium p-4 mb-4 text-center bg-danger bg-opacity-10 border-danger border-opacity-25">
        <i class="bi bi-telephone-fill text-danger fs-1 mb-3 d-block"></i>
        <h4 class="fw-bold text-danger mb-2">Kondisi Memburuk?</h4>
        <p class="small text-muted mb-3">Jika korban tidak sadar, pendarahan tidak kunjung berhenti, atau kondisi memburuk, segera hubungi kontak darurat medis terdekat.</p>
        <a href="tel:119" class="phone-pill w-100 py-3 mb-2"><i class="bi bi-telephone-outbound me-2"></i>Hubungi Ambulans (119)</a>
        <a href="/contacts" class="btn btn-sm btn-outline-danger w-100 rounded-pill mt-2">Daftar Kontak Lainnya</a>
      </div>

      <!-- Related Guides Card -->
      <div class="card-premium p-4">
        <h5 class="fw-bold mb-3"><i class="bi bi-bookmark-plus me-2 text-primary"></i>Panduan Terkait</h5>
        <div class="list-group list-group-flush">
          <% if (recommendations && recommendations.length > 0) { %>
            <% recommendations.forEach(rec => { %>
              <div class="list-group-item border-0 px-0 py-3">
                <div class="row g-2 align-items-center">
                  <div class="col-4">
                    <% if (rec.gambar) { %>
                      <img src="/uploads/<%= rec.gambar %>" alt="<%= rec.judul %>" class="img-fluid rounded" style="height: 60px; width: 100%; object-fit: cover;">
                    <% } else { %>
                      <div class="bg-light d-flex align-items-center justify-content-center rounded text-danger" style="height: 60px; width: 100%;">
                        <i class="bi bi-heart-pulse"></i>
                      </div>
                    <% } %>
                  </div>
                  <div class="col-8">
                    <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill small mb-1" style="font-size: 0.75rem;"><%= rec.kategori_nama %></span>
                    <h6 class="mb-0 small fw-bold">
                      <a href="/guides/<%= rec.id %>" class="text-decoration-none text-dark hover-danger text-truncate-2"><%= rec.judul %></a>
                    </h6>
                  </div>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <p class="small text-muted mb-0">Tidak ada rekomendasi panduan lain yang sejenis.</p>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
