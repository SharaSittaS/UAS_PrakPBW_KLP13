<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container my-5">
  <!-- Title Header -->
  <div class="text-center mb-5">
    <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3 py-2 fw-semibold mb-2">DIREKTORI MEDIS</span>
    <h1 class="fw-bold mb-2">Panduan Pertolongan Pertama</h1>
    <p class="text-muted col-lg-6 mx-auto">Cari pertolongan cepat berdasarkan nama kondisi atau gejala spesifik yang dialami korban.</p>
  </div>

  <div class="row g-4">
    <!-- Sidebar Filter (Column 3) -->
    <div class="col-lg-3">
      <!-- Search Card -->
      <div class="card-premium p-4 mb-4">
        <h5 class="fw-bold mb-3"><i class="bi bi-search me-2 text-danger"></i>Cari Panduan</h5>
        <form action="/guides" method="GET">
          <!-- Kirim filter kategori jika ada -->
          <% if (selectedCategory) { %>
            <input type="hidden" name="c" value="<%= selectedCategory %>">
          <% } %>
          <div class="mb-3">
            <input type="text" name="q" class="form-control" placeholder="Kata kunci..." value="<%= search %>">
          </div>
          <button type="submit" class="btn btn-danger w-100 rounded-pill"><i class="bi bi-search me-1"></i> Temukan</button>
          <% if (search || selectedCategory) { %>
            <a href="/guides" class="btn btn-outline-secondary w-100 rounded-pill mt-2 btn-sm"><i class="bi bi-x-circle me-1"></i> Reset Filter</a>
          <% } %>
        </form>
      </div>

      <!-- Categories Card -->
      <div class="card-premium p-4">
        <h5 class="fw-bold mb-3"><i class="bi bi-grid me-2 text-primary"></i>Kategori</h5>
        <div class="list-group list-group-flush">
          <a href="/guides<%= search ? '?q=' + search : '' %>" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center border-0 px-0 <%= selectedCategory === '' ? 'text-danger fw-bold' : 'text-muted' %>">
            <span>Semua Kategori</span>
            <i class="bi bi-chevron-right small"></i>
          </a>
          
          <% categories.forEach(category => { %>
            <a href="/guides?c=<%= category.id %><%= search ? '&q=' + search : '' %>" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center border-0 px-0 <%= selectedCategory == category.id ? 'text-danger fw-bold' : 'text-muted' %>">
              <span class="text-truncate"><%= category.nama %></span>
              <i class="bi bi-chevron-right small"></i>
            </a>
          <% }) %>
        </div>
      </div>
    </div>

    <!-- Guides List Grid (Column 9) -->
    <div class="col-lg-9">
      <!-- Active filters bar -->
      <% if (search || selectedCategory) { %>
        <div class="alert alert-light border shadow-sm rounded-3 p-3 mb-4 d-flex justify-content-between align-items-center">
          <div class="small text-muted mb-0">
            Ditemukan <strong><%= guides.length %></strong> hasil pencarian
            <% if (search) { %> untuk kata kunci "<strong><%= search %></strong>"<% } %>
            <% if (selectedCategory) { %>
              <% const catObj = categories.find(c => c.id == selectedCategory); %>
              <% if (catObj) { %> dalam kategori "<strong><%= catObj.nama %></strong>"<% } %>
            <% } %>
          </div>
          <a href="/guides" class="btn btn-sm btn-outline-secondary rounded-pill px-3"><i class="bi bi-arrow-counterclockwise me-1"></i> Reset</a>
        </div>
      <% } %>

      <div class="row g-4">
        <% if (guides && guides.length > 0) { %>
          <% guides.forEach(guide => { %>
            <div class="col-md-6">
              <div class="card card-premium h-100 d-flex flex-column justify-content-between">
                <div>
                  <% if (guide.gambar) { %>
                    <img src="/uploads/<%= guide.gambar %>" class="card-img-top" alt="<%= guide.judul %>" style="height: 180px; object-fit: cover;">
                  <% } else { %>
                    <div class="placeholder-guide-img" style="height: 180px;">
                      <i class="bi bi-heart-pulse text-danger fs-2 mb-2"></i>
                      <span class="d-block w-100 text-center text-muted small"><%= guide.kategori_nama %></span>
                    </div>
                  <% } %>
                  
                  <div class="card-body p-4">
                    <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill mb-2"><%= guide.kategori_nama %></span>
                    <h5 class="card-title mb-2">
                      <a href="/guides/<%= guide.id %>" class="text-decoration-none text-dark hover-danger"><%= guide.judul %></a>
                    </h5>
                    <p class="card-text text-muted small">
                      <strong>Gejala:</strong> <%= guide.gejala.substring(0, 80) %>...
                    </p>
                  </div>
                </div>
                
                <div class="card-footer bg-transparent border-0 px-4 pb-4 pt-0">
                  <hr class="mt-0 mb-3 text-black-50">
                  <div class="d-flex justify-content-between align-items-center">
                    <span class="text-muted small"><i class="bi bi-calendar3 me-1"></i> <%= new Date(guide.created_at).toLocaleDateString('id-ID') %></span>
                    <a href="/guides/<%= guide.id %>" class="btn btn-sm btn-danger rounded-pill px-3">Detail <i class="bi bi-chevron-right ms-1"></i></a>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="col-12 text-center py-5">
            <i class="bi bi-journal-x text-muted" style="font-size: 5rem;"></i>
            <h4 class="mt-3 fw-bold text-secondary">Panduan Tidak Ditemukan</h4>
            <p class="text-muted">Cobalah untuk menggunakan kata kunci pencarian yang lain atau ganti filter kategori.</p>
            <a href="/guides" class="btn btn-danger rounded-pill px-4 mt-2">Lihat Semua Panduan</a>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
