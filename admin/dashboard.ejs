<%- include('../partials/header') %>

<div class="container-fluid">
  <div class="row">
    <!-- Sidebar (Column 3) -->
    <div class="col-md-3 col-lg-2 px-0 sidebar d-flex flex-column justify-content-between">
      <div>
        <div class="p-3 text-center border-bottom border-secondary">
          <h4 class="fw-bold mb-0 text-white"><i class="bi bi-heart-pulse-fill text-danger me-2"></i>FirstAid</h4>
          <span class="text-muted small">Panel Admin</span>
        </div>
        <div class="py-3">
          <ul class="nav nav-pills flex-column mb-auto">
            <li class="nav-item">
              <a href="/admin/dashboard" class="nav-link active">
                <i class="bi bi-speedometer2 me-2"></i> Dashboard
              </a>
            </li>
            <li>
              <a href="/admin/guides" class="nav-link">
                <i class="bi bi-journal-medical me-2"></i> Panduan
              </a>
            </li>
            <li>
              <a href="/admin/categories" class="nav-link">
                <i class="bi bi-grid me-2"></i> Kategori
              </a>
            </li>
            <li>
              <a href="/admin/contacts" class="nav-link">
                <i class="bi bi-telephone-plus me-2"></i> Kontak Darurat
              </a>
            </li>
          </ul>
        </div>
      </div>
      
      <div class="p-3 border-top border-secondary">
        <a href="/" class="btn btn-sm btn-outline-light w-100 rounded-pill mb-2"><i class="bi bi-globe me-1"></i> Lihat Web</a>
        <a href="/auth/logout" class="btn btn-sm btn-danger w-100 rounded-pill"><i class="bi bi-box-arrow-right me-1"></i> Keluar</a>
      </div>
    </div>

    <!-- Main Content Area (Column 9) -->
    <div class="col-md-9 col-lg-10 bg-light py-4 px-md-4" style="min-height: 100vh;">
      <!-- Top Alert Message (Jika ada) -->
      <% if (message) { %>
        <div class="alert alert-<%= message.type %> alert-dismissible fade show border-0 shadow-sm" role="alert">
          <%= message.text %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% } %>

      <!-- Greeting & Header -->
      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <h1 class="h2 fw-bold mb-0">Dashboard</h1>
          <p class="text-muted mb-0">Selamat datang, <strong><%= user.nama %></strong>. Berikut rangkuman data saat ini.</p>
        </div>
        <div class="text-muted small d-none d-md-block">
          <i class="bi bi-calendar3 me-1"></i> <%= new Date().toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
        </div>
      </div>

      <!-- Stats Cards -->
      <div class="row g-3 mb-4">
        <!-- Card Guides -->
        <div class="col-md-4">
          <div class="card-premium p-4 border-start border-danger border-5 bg-white">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <h6 class="text-muted text-uppercase small fw-bold mb-1">Total Panduan</h6>
                <h3 class="fw-bold mb-0 text-dark"><%= stats.guides %></h3>
              </div>
              <div class="bg-danger bg-opacity-10 text-danger rounded-circle p-3">
                <i class="bi bi-journal-medical fs-3"></i>
              </div>
            </div>
            <a href="/admin/guides" class="small text-danger text-decoration-none d-block mt-3">Kelola data <i class="bi bi-arrow-right"></i></a>
          </div>
        </div>

        <!-- Card Categories -->
        <div class="col-md-4">
          <div class="card-premium p-4 border-start border-primary border-5 bg-white">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <h6 class="text-muted text-uppercase small fw-bold mb-1">Total Kategori</h6>
                <h3 class="fw-bold mb-0 text-dark"><%= stats.categories %></h3>
              </div>
              <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-3">
                <i class="bi bi-grid fs-3"></i>
              </div>
            </div>
            <a href="/admin/categories" class="small text-primary text-decoration-none d-block mt-3">Kelola data <i class="bi bi-arrow-right"></i></a>
          </div>
        </div>

        <!-- Card Contacts -->
        <div class="col-md-4">
          <div class="card-premium p-4 border-start border-success border-5 bg-white">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <h6 class="text-muted text-uppercase small fw-bold mb-1">Kontak Darurat</h6>
                <h3 class="fw-bold mb-0 text-dark"><%= stats.contacts %></h3>
              </div>
              <div class="bg-success bg-opacity-10 text-success rounded-circle p-3">
                <i class="bi bi-telephone-fill fs-3"></i>
              </div>
            </div>
            <a href="/admin/contacts" class="small text-success text-decoration-none d-block mt-3">Kelola data <i class="bi bi-arrow-right"></i></a>
          </div>
        </div>
      </div>

      <div class="row g-4">
        <!-- Recent Guides Log (Col-lg-8) -->
        <div class="col-lg-8">
          <div class="card card-premium p-4 bg-white h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <h5 class="fw-bold mb-0"><i class="bi bi-clock-history me-2 text-danger"></i>Aktivitas Panduan Terbaru</h5>
              <a href="/admin/guides/create" class="btn btn-sm btn-danger rounded-pill px-3"><i class="bi bi-plus-circle me-1"></i> Tambah Panduan</a>
            </div>
            
            <div class="table-responsive">
              <table class="table align-middle">
                <thead>
                  <tr class="small text-muted">
                    <th>Judul Panduan</th>
                    <th>Kategori</th>
                    <th>Tanggal Dibuat</th>
                    <th class="text-end">Aksi</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (recentGuides && recentGuides.length > 0) { %>
                    <% recentGuides.forEach(guide => { %>
                      <tr>
                        <td>
                          <span class="fw-bold text-dark d-block text-truncate" style="max-width: 250px;"><%= guide.judul %></span>
                        </td>
                        <td>
                          <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill"><%= guide.kategori_nama %></span>
                        </td>
                        <td>
                          <span class="small text-muted"><%= new Date(guide.created_at).toLocaleDateString('id-ID') %></span>
                        </td>
                        <td class="text-end">
                          <a href="/admin/guides/edit/<%= guide.id %>" class="btn btn-sm btn-light text-primary border rounded-circle" title="Edit"><i class="bi bi-pencil-fill"></i></a>
                        </td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr>
                      <td colspan="4" class="text-center py-4 text-muted small">Belum ada panduan terdaftar.</td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Shortcuts Card (Col-lg-4) -->
        <div class="col-lg-4">
          <div class="card card-premium p-4 bg-white h-100">
            <h5 class="fw-bold mb-3"><i class="bi bi-lightning-fill text-warning me-2"></i>Aksi Cepat</h5>
            <div class="d-grid gap-2">
              <a href="/admin/guides/create" class="btn btn-light border text-start py-2.5 px-3 rounded-3 hover-shadow d-flex align-items-center justify-content-between">
                <div>
                  <i class="bi bi-journal-medical text-danger me-2"></i>
                  <span class="fw-semibold small">Tambah Panduan Baru</span>
                </div>
                <i class="bi bi-chevron-right small text-muted"></i>
              </a>

              <a href="/admin/categories/create" class="btn btn-light border text-start py-2.5 px-3 rounded-3 hover-shadow d-flex align-items-center justify-content-between">
                <div>
                  <i class="bi bi-grid text-primary me-2"></i>
                  <span class="fw-semibold small">Tambah Kategori Baru</span>
                </div>
                <i class="bi bi-chevron-right small text-muted"></i>
              </a>

              <a href="/admin/contacts/create" class="btn btn-light border text-start py-2.5 px-3 rounded-3 hover-shadow d-flex align-items-center justify-content-between">
                <div>
                  <i class="bi bi-telephone-plus text-success me-2"></i>
                  <span class="fw-semibold small">Tambah Kontak Baru</span>
                </div>
                <i class="bi bi-chevron-right small text-muted"></i>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
