<%- include('../../partials/header') %>

<div class="container-fluid">
  <div class="row">
    <!-- Sidebar -->
    <div class="col-md-3 col-lg-2 px-0 sidebar d-flex flex-column justify-content-between">
      <div>
        <div class="p-3 text-center border-bottom border-secondary">
          <h4 class="fw-bold mb-0 text-white"><i class="bi bi-heart-pulse-fill text-danger me-2"></i>FirstAid</h4>
          <span class="text-muted small">Panel Admin</span>
        </div>
        <div class="py-3">
          <ul class="nav nav-pills flex-column mb-auto">
            <li>
              <a href="/admin/dashboard" class="nav-link">
                <i class="bi bi-speedometer2 me-2"></i> Dashboard
              </a>
            </li>
            <li>
              <a href="/admin/guides" class="nav-link">
                <i class="bi bi-journal-medical me-2"></i> Panduan
              </a>
            </li>
            <li>
              <a href="/admin/categories" class="nav-link active">
                <i class="bi bi-grid me-2"></i> Kategori
              </a>
            </li>
            <li>
              <a href="/admin/contacts" class="nav-link">
                <i class="bi bi-telephone-plus me-2"></i> Kontak Darurat
              </a>
            </li>
          </ul>
        </div>
      </div>
      
      <div class="p-3 border-top border-secondary">
        <a href="/" class="btn btn-sm btn-outline-light w-100 rounded-pill mb-2"><i class="bi bi-globe me-1"></i> Lihat Web</a>
        <a href="/auth/logout" class="btn btn-sm btn-danger w-100 rounded-pill"><i class="bi bi-box-arrow-right me-1"></i> Keluar</a>
      </div>
    </div>

    <!-- Main Content Area -->
    <div class="col-md-9 col-lg-10 bg-light py-4 px-md-4" style="min-height: 100vh;">
      
      <!-- Top Alert Message -->
      <% if (message) { %>
        <div class="alert alert-<%= message.type %> alert-dismissible fade show border-0 shadow-sm" role="alert">
          <%= message.text %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% } %>

      <!-- Breadcrumbs / Back navigation -->
      <div class="mb-4">
        <a href="/admin/categories" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
          <i class="bi bi-arrow-left me-1"></i> Kembali ke Daftar Kategori
        </a>
      </div>

      <!-- Header -->
      <div class="mb-4">
        <h1 class="h2 fw-bold mb-0">Ubah Kategori</h1>
        <p class="text-muted">Perbarui data kategori <strong><%= category.nama %></strong>.</p>
      </div>

      <!-- Edit Form Card -->
      <div class="card card-premium p-4 p-md-5 bg-white" style="max-width: 800px;">
        <form action="/admin/categories/edit/<%= category.id %>" method="POST" class="needs-validation" novalidate>
          <!-- Nama Kategori -->
          <div class="mb-3">
            <label for="nama" class="form-label fw-bold">Nama Kategori <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="nama" name="nama" value="<%= category.nama %>" placeholder="Contoh: Luka Bakar, Tersedak" required>
            <div class="invalid-feedback">Nama kategori wajib diisi.</div>
          </div>

          <!-- Deskripsi -->
          <div class="mb-4">
            <label for="deskripsi" class="form-label fw-bold">Deskripsi</label>
            <textarea class="form-control" id="deskripsi" name="deskripsi" rows="4" placeholder="Jelaskan mengenai cakupan kategori pertolongan pertama ini..."><%= category.deskripsi %></textarea>
          </div>

          <!-- Submit buttons -->
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-premium btn-premium-primary">
              <i class="bi bi-check-circle me-2"></i>Simpan Perubahan
            </button>
            <a href="/admin/categories" class="btn btn-premium btn-outline-secondary px-4 py-2">Batal</a>
          </div>
        </form>
      </div>

    </div>
  </div>
</div>

<script>
  // Enable Bootstrap form validation
  (function () {
    'use strict'
    var forms = document.querySelectorAll('.needs-validation')
    Array.prototype.slice.call(forms)
      .forEach(function (form) {
        form.addEventListener('submit', function (event) {
          if (!form.checkValidity()) {
            event.preventDefault()
            event.stopPropagation()
          }
          form.classList.add('was-validated')
        }, false)
      })
  })()
</script>

<%- include('../../partials/footer') %>
